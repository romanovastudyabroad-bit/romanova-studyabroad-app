<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Romanova Study Abroad</title>
<style>
  :root {
    --bg: #F5F1E8;
    --bg2: #E8E3D8;
    --navy: #1A3A52;
    --green: #2C5530;
    --burgundy: #6B2737;
    --burgundy-dark: #4A1A25;
    --green-dark: #1E3A21;
    --gold: #B8956A;
    --gold-dark: #9A7A56;
    --text: #2C2C2C;
    --text2: #4A4A4A;
    --white: #FAFAFA;
  }
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color: transparent; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    max-width: 480px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  /* SCREENS */
  .screen { display:none; min-height:100vh; padding-bottom: 90px; animation: fadeIn 0.18s ease; }
  .screen.active { display:block; }
  @keyframes fadeIn { from { opacity:0; transform: translateY(6px); } to { opacity:1; transform: translateY(0); } }

  /* HEADER */
  .header {
    background: var(--navy);
    padding: 0 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    height: 52px;
  }
  .header-logo { font-size: 14px; font-weight: 700; color: var(--white); }
  .back-btn {
    background: none; border: none; color: var(--white);
    font-size: 26px; cursor: pointer;
    min-width: 44px; min-height: 44px;
    display: flex; align-items: center; justify-content: center;
    opacity: 0.9;
  }
  .back-btn:active { opacity: 0.6; }
  .header-spacer { width: 44px; }

  /* HERO */
  .hero {
    background: linear-gradient(160deg, var(--navy) 0%, #0f2538 100%);
    padding: 28px 20px 24px;
    text-align: center;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(184,149,106,0.2);
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    padding: 4px 12px; border-radius: 20px; margin-bottom: 14px;
  }
  .hero h1 { color: var(--white); font-size: 22px; font-weight: 800; line-height: 1.3; margin-bottom: 8px; }
  .hero-desc { color: rgba(255,255,255,0.7); font-size: 13px; line-height: 1.6; margin-bottom: 20px; }
  .hero-stats { display: flex; justify-content: center; gap: 0; margin-bottom: 24px; }
  .stat { text-align: center; flex: 1; padding: 0 8px; }
  .stat + .stat { border-left: 1px solid rgba(255,255,255,0.15); }
  .stat-num { color: var(--gold); font-size: 20px; font-weight: 800; display:block; }
  .stat-label { color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 2px; }
  .stat-context { color: rgba(255,255,255,0.35); font-size: 9px; }

  /* BUTTONS */
  .btn {
    display: block; width: 100%;
    padding: 14px 18px; border-radius: 12px; border: none;
    font-size: 14px; font-weight: 600; cursor: pointer;
    text-align: center; text-decoration: none;
    transition: all 0.15s; margin-bottom: 10px;
    font-family: inherit;
  }
  .btn:active { transform: scale(0.98); }
  .btn-primary { background: var(--burgundy); color: var(--white); }
  .btn-primary:active { background: var(--burgundy-dark); }
  .btn-secondary { background: var(--green); color: var(--white); }
  .btn-secondary:active { background: var(--green-dark); }
  .btn-ghost { background: transparent; color: var(--navy); border: 1.5px solid var(--bg2); background: var(--white); }
  .btn-ghost:active { background: var(--bg2); }
  .btn-gold { background: var(--gold); color: var(--white); }
  .btn-gold:active { background: var(--gold-dark); }

  /* TEXT LINK — вместо кнопок для вторичных действий */
  .text-links { margin-top: 6px; }
  .text-link {
    display: block;
    text-align: center;
    color: var(--text2);
    font-size: 13px;
    padding: 10px 0;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--bg2);
    text-underline-offset: 3px;
    transition: color 0.15s;
    border: none; background: none; width: 100%; font-family: inherit;
  }
  .text-link:active { color: var(--navy); }

  /* CONTENT */
  .content { padding: 20px 18px; }

  /* SECTION TITLE */
  .section-title { color: var(--navy); font-size: 19px; font-weight: 800; margin-bottom: 6px; line-height: 1.3; }
  .section-subtitle { color: var(--text2); font-size: 13px; margin-bottom: 20px; line-height: 1.55; }

  /* SECTION ACCENT BAR */
  .section-accent {
    height: 4px; border-radius: 2px; margin-bottom: 20px;
    background: linear-gradient(90deg, var(--burgundy), var(--gold));
  }
  .section-accent.green { background: linear-gradient(90deg, var(--green), var(--gold)); }
  .section-accent.navy { background: linear-gradient(90deg, var(--navy), var(--green)); }

  /* HOME QUICK LINKS */
  .quick-links { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
  .quick-card {
    background: var(--white);
    border: 1.5px solid var(--bg2);
    border-radius: 14px;
    padding: 16px 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: all 0.15s;
  }
  .quick-card:active { border-color: var(--navy); background: var(--bg2); }
  .quick-card-icon { font-size: 26px; flex-shrink: 0; }
  .quick-card-body { flex: 1; }
  .quick-card-title { font-size: 14px; font-weight: 700; color: var(--navy); }
  .quick-card-sub { font-size: 12px; color: var(--text2); margin-top: 2px; }
  .quick-card-arrow { color: var(--bg2); font-size: 18px; flex-shrink:0; }

  /* FORMAT CARDS — кликабельные */
  .format-card {
    background: var(--white);
    border: 1.5px solid var(--bg2);
    border-radius: 14px;
    padding: 16px 18px;
    margin-bottom: 10px;
    cursor: pointer;
    display: flex; align-items: center; gap: 12px;
    transition: all 0.15s;
  }
  .format-card:active { border-color: var(--navy); background: var(--bg2); }
  .format-card.featured { border-color: var(--burgundy); }
  .format-card.gold { border-color: var(--gold); }
  .format-card-body { flex: 1; }
  .format-card-title { font-size: 13px; font-weight: 700; color: var(--green); margin-bottom: 2px; }
  .format-card-title.gold { color: var(--gold); }
  .format-card-price { font-size: 17px; font-weight: 800; color: var(--navy); }
  .format-card-desc { font-size: 12px; color: var(--text2); margin-top: 3px; line-height: 1.4; }
  .format-card-arrow { color: var(--bg2); font-size: 18px; flex-shrink:0; }
  .format-card.featured .format-card-arrow { color: var(--burgundy); }
  .format-card.gold .format-card-arrow { color: var(--gold); }

  /* DETAIL CARD (внутри страниц форматов) */
  .detail-card {
    background: var(--white); border: 1.5px solid var(--bg2);
    border-radius: 12px; padding: 16px 18px; margin-bottom: 12px;
  }
  .detail-card.featured { border-color: var(--burgundy); }
  .detail-card.gold { border-color: var(--gold); }
  .card-label { font-size: 11px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--green); margin-bottom: 6px; }
  .card-label.gold { color: var(--gold); }
  .card-price { font-size: 20px; font-weight: 800; color: var(--navy); margin-bottom: 4px; }
  .card-desc { font-size: 13px; color: var(--text2); line-height: 1.55; }

  /* FEATURES */
  .features { list-style: none; margin: 10px 0; }
  .features li { font-size: 13px; color: var(--text); padding: 5px 0; display: flex; gap: 8px; line-height: 1.4; border-bottom: 1px solid var(--bg2); }
  .features li:last-child { border-bottom: none; }
  .features li::before { content: "✓"; color: var(--green); font-weight: 800; flex-shrink:0; }

  /* DIVIDER */
  .divider { height: 1px; background: var(--bg2); margin: 18px 0; }

  /* HIGHLIGHT */
  .highlight {
    background: var(--bg2); border-left: 3px solid var(--burgundy);
    border-radius: 0 10px 10px 0; padding: 12px 14px; margin-bottom: 16px;
  }
  .highlight p { font-size: 13px; color: var(--text); line-height: 1.55; }
  .highlight.green { border-color: var(--green); }
  .highlight.gold { border-color: var(--gold); }

  /* TEST */
  .test-progress-wrap { margin-bottom: 24px; }
  .test-step-label { font-size: 12px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; font-weight: 600; }
  .test-progress { display: flex; gap: 6px; }
  .progress-bar { flex: 1; height: 8px; background: var(--bg2); border-radius: 4px; transition: background 0.3s; }
  .progress-bar.active { background: var(--burgundy); }
  .progress-bar.done { background: var(--green); }

  .test-question { color: var(--navy); font-size: 19px; font-weight: 800; margin-bottom: 22px; line-height: 1.4; }

  .option-btn {
    display: block; width: 100%;
    background: var(--white); border: 1.5px solid var(--bg2);
    border-radius: 12px; padding: 14px 16px; margin-bottom: 10px;
    font-size: 14px; color: var(--text); text-align: left;
    cursor: pointer; transition: all 0.15s; font-family: inherit; font-weight: 500;
  }
  .option-btn:active { border-color: var(--burgundy); background: #fdf7f7; color: var(--burgundy); }

  /* RESULT */
  .result-hero {
    background: linear-gradient(160deg, var(--green) 0%, var(--navy) 100%);
    padding: 24px 20px;
    margin-bottom: 0;
  }
  .result-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.15);
    color: var(--white); font-size: 11px; font-weight: 700;
    padding: 4px 12px; border-radius: 20px; margin-bottom: 12px;
  }
  .result-context {
    color: rgba(255,255,255,0.75); font-size: 13px; line-height: 1.6;
    margin-bottom: 0;
  }
  .result-title { color: var(--white); font-size: 20px; font-weight: 800; line-height: 1.3; margin-bottom: 8px; }

  /* FAQ */
  .faq-item { border-bottom: 1px solid var(--bg2); }
  .faq-q {
    padding: 15px 4px; font-size: 14px; font-weight: 600; color: var(--navy);
    cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 10px;
  }
  .faq-q .arrow { transition: transform 0.25s; font-size: 12px; color: var(--text2); flex-shrink:0; }
  .faq-q.open .arrow { transform: rotate(180deg); }
  .faq-a { display: none; padding: 0 0 16px; font-size: 13px; color: var(--text2); line-height: 1.65; }
  .faq-a.show { display: block; }
  .faq-cta { display: inline-block; margin-top: 10px; color: var(--burgundy); font-size: 12px; font-weight: 700; cursor: pointer; text-decoration: underline; }

  /* CONTACT ROW */
  .contact-row {
    display: flex; align-items: center; gap: 12px;
    background: var(--white); border: 1.5px solid var(--bg2);
    border-radius: 12px; padding: 14px 16px; margin-bottom: 10px;
    text-decoration: none; color: var(--text); transition: border-color 0.15s;
  }
  .contact-row:active { border-color: var(--navy); }
  .contact-icon { font-size: 22px; }
  .contact-info { flex: 1; }
  .contact-name { font-size: 13px; font-weight: 600; color: var(--navy); }
  .contact-val { font-size: 12px; color: var(--text2); }

  /* PATH CARD */
  .path-card { background: var(--white); border: 1.5px solid var(--bg2); border-radius: 12px; padding: 16px; margin-bottom: 10px; }
  .path-num {
    display: inline-block; background: var(--navy); color: var(--white);
    font-size: 11px; font-weight: 700; width: 24px; height: 24px;
    border-radius: 50%; text-align: center; line-height: 24px; margin-bottom: 8px;
  }
  .path-title { color: var(--navy); font-size: 15px; font-weight: 700; margin-bottom: 3px; }
  .path-sub { color: var(--text2); font-size: 12px; line-height: 1.4; }

  /* DEADLINE */
  .deadline { background: var(--burgundy); color: var(--white); font-size: 13px; font-weight: 700; padding: 10px 16px; border-radius: 10px; text-align: center; margin-bottom: 18px; }

  /* BOTTOM NAV */
  .bottom-nav {
    position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 100%; max-width: 480px;
    background: var(--white); border-top: 1px solid var(--bg2);
    display: flex; z-index: 200;
    box-shadow: 0 -2px 16px rgba(0,0,0,0.07);
  }
  .nav-item {
    flex: 1; padding: 10px 4px 8px; text-align: center;
    cursor: pointer; border: none; background: none; font-family: inherit;
  }
  .nav-icon { font-size: 21px; display: block; }
  .nav-label { font-size: 9px; color: var(--text2); display: block; margin-top: 2px; font-weight: 500; }
  .nav-item.active .nav-label { color: var(--burgundy); font-weight: 700; }

  /* STATS ROW */
  .stats-row { display: flex; gap: 8px; margin-bottom: 14px; }
  .stat-card { flex: 1; background: var(--white); border: 1.5px solid var(--bg2); border-radius: 12px; padding: 14px 10px; text-align: center; }
  .stat-card-num { font-size: 20px; font-weight: 800; color: var(--navy); display: block; }
  .stat-card-label { font-size: 11px; color: var(--text2); margin-top: 2px; }

  a.btn, a.contact-row { display: block; }
</style>
</head>
